{
    "name": "trello-board-hw",
    "version": "1.0.0",
    "description": "Homework: Trello-like board with file handling and DnD",
    "private": true,
    "scripts": {
        "start": "node ./node_modules/webpack-cli/bin/cli.js serve --mode development --open",
        "build": "node ./node_modules/webpack-cli/bin/cli.js --mode production",
        "lint": "eslint .",
        "test": "jest",
        "test:ci": "jest --ci --runInBand",
        "repair:yarn": "node scripts/repair-yarn.mjs",
        "doctor:webpack": "node -e \"const fs=require('fs');const p='node_modules/webpack/bin/webpack.js';if(fs.existsSync(p)){console.log('ok:',p);process.exit(0)}console.error('missing:',p);process.exit(1)\"",
        "repair:source": "node scripts/repair-source.mjs"
    },
    "devDependencies": {
        "@babel/core": "^7.26.0",
        "@babel/preset-env": "^7.26.0",
        "babel-jest": "^29.7.0",
        "babel-loader": "^9.2.1",
        "clean-webpack-plugin": "^4.0.0",
        "css-loader": "^7.1.2",
        "eslint": "^9.16.0",
        "eslint-config-airbnb-base": "^15.0.0",
        "eslint-plugin-import": "^2.31.0",
        "html-webpack-plugin": "^5.6.3",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^29.7.0",
        "style-loader": "^4.0.0",
        "webpack": "^5.97.1",
        "webpack-cli": "^6.0.1",
        "webpack-dev-server": "^5.2.0"
    },
    "packageManager": "yarn@4.12.0"
}
