{
    "env": {
        "browser": true,
        "es2021": true,
        "jest": true
    },
    "extends": [ "airbnb-base" ],
    "parserOptions": {
        "ecmaVersion": "latest",
        "sourceType": "module"
    },
    "rules": {
        "no-param-reassign": [
            "error",
            { "props": false }
        ],
        "import/extensions": [
            "error",
            "always",
            { "js": "never" }
        ],
        "no-underscore-dangle": "off"
    }
}
